# Default: ignore everything in the server directory (this is the actual
# server installation). Only explicitly allowed files and folders below
# are kept under version control for this project.
/*

# Keep git metadata
!.gitignore
!.github

# Allow project scripts at repository root
!/*.ps1
!/*.bat

# Keep README and license in repo
!/README.md
!/LICENSE
!/AGENTS.md

# Allow project folders and their contents
!/scripts/
!/scripts/**
!/tests/
!/tests/**
!/tools/
!/tools/**

# Local overrides and templates should be kept out of VCS (templates can stay)
*.local.ps1

# Runtime files and backups should not be committed
backups/
Storage/
